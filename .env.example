# ─── AI Provider Keys ─────────────────────────────────
# At least one AI key is required for BushidoOS to function.
# Gemini is recommended (used by default). Get a key at: https://aistudio.google.com/apikey

VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI-compatible API (used as fallback)
# VITE_OPENAI_API_KEY=your_openai_key_here

# Optional: DeepSeek (budget-friendly alternative)
# VITE_DEEPSEEK_API_KEY=your_deepseek_key_here

# ─── Research (Optional) ──────────────────────────────
# Tavily API key for deep market research in `bushido kickstart`
# Get one at: https://tavily.com
# VITE_TAVILY_API_KEY=your_tavily_key_here

# ─── Cloud Sync (Optional) ────────────────────────────
# Supabase project for `bushido push` / `bushido pull`
# Create a project at: https://supabase.com
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here
